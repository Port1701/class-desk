# ─── APPLICATION CORE ───────────────────────────────────────────────────────

# [REQUIRED] Port for the Express server to listen on (default: 8080)
PORT=8080

# [REQUIRED] Node.js environment: development, production, or test
NODE_ENV=development

# [OPTIONAL] Enable verbose debug logging. Set to 'true' for development (default: false)
DEBUG=false

# [OPTIONAL] Bypass authentication checks for development/testing (default: false)
# ⚠️  SECURITY: Never set to true in production!
BYPASS_AUTH=false

# ─── DATABASE & CACHE ────────────────────────────────────────────────────────

# [REQUIRED] Supabase project URL for PostgreSQL database and auth
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=

# [REQUIRED] Supabase secret key (for server-to-server requests)
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_SECRET_KEY=sb_secret_

# [OPTIONAL] PostgreSQL database password (only needed for direct DB connections)
SUPABASE_DB_PASSWORD=

# [OPTIONAL] Redis connection URL for caching and rate limiting (default: redis://localhost:6379)
# Server degrades gracefully if Redis is unavailable
REDIS_URL=redis://localhost:6379

# ─── SECURITY & CORS ─────────────────────────────────────────────────────────

# [REQUIRED] Comma-separated list of allowed CORS origins for frontend requests
CORS_ORIGINS=http://localhost:3000

# ─── AI & LLM SERVICES ───────────────────────────────────────────────────────

# [REQUIRED] Anthropic Claude API key for chatbot LLM completions
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-

# [OPTIONAL] OpenAI API key for text embeddings in RAG system
# Used for vector search if no other embedding service is configured
OPENAI_API_KEY=sk-

# ─── OBSERVABILITY & TRACING ──────────────────────────────────────────────────

# [OPTIONAL] Langfuse public key for tracing and analytics
# Get from: https://cloud.langfuse.com/project/settings/keys
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key

# [OPTIONAL] Langfuse secret key for secure server-side requests
# Get from: https://cloud.langfuse.com/project/settings/keys
LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# [OPTIONAL] Langfuse base URL (default: https://cloud.langfuse.com)
# Use https://us.cloud.langfuse.com for US region, https://eu.cloud.langfuse.com for EU
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── ADMIN CONSOLE ────────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated list of admin email addresses
# Users with these emails can access the admin dashboard
ADMIN_EMAILS=

# ─── INTERNAL API KEY ─────────────────────────────────────────────────────────

# [OPTIONAL] Secret key for internal service-to-service authentication
# Pass as request header: x-internal-api-key: <your-key>
# Grants access to maintenance endpoints: embed-all, re-embed, metrics, prompts
# If not set, internal key auth is disabled — all access requires a user JWT
# ⚠️  SECURITY: Treat this like a password — rotate if compromised
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# ─── FORM SUBMISSION (Monday.com) ─────────────────────────────────────────────

# [OPTIONAL] Monday.com form 1 URL
MONDAY_FORM_1_URL=

# [OPTIONAL] Monday.com form 2 URL
MONDAY_FORM_2_URL=

# [OPTIONAL] Name/username to use when submitting forms (default: "🤖 ClassDesk")
FORM_VOLUNTEER_NAME=

# [OPTIONAL] When true, form submissions return success without actually submitting (default: false)
# Useful for testing the form flow without side effects
FORM_DRY_RUN=false

# ─── EMAIL (Mailgun) ──────────────────────────────────────────────────────────

# [OPTIONAL] Mailgun API key (secret key) for sending confirmation emails
# If not set, email sending is disabled (form submissions still work)
MAILGUN_API_KEY=

# [OPTIONAL] Mailgun verified sending domain
# Required only if MAILGUN_API_KEY is set
MAILGUN_DOMAIN=

# [OPTIONAL] Email sender address in "Name <email@domain>" format (default: "ClassDesk <info@example.org>")
MAILGUN_FROM=

# [OPTIONAL] Mailgun API base URL (default: https://api.mailgun.net)
# Use https://api.mailgun.net for US or https://api.eu.mailgun.net for EU region
MAILGUN_API_BASE_URL=https://api.mailgun.net
