# ─── APPLICATION ────────────────────────────────────────────────────────────

# [OPTIONAL] Frontend app URL (default: http://localhost:3000)
# Used for constructing absolute URLs in email links and redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── BACKEND API ─────────────────────────────────────────────────────────────

# [REQUIRED] Backend Express API URL for fetching data and making requests
# Local: http://localhost:8080
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── AUTHENTICATION & DATABASE (Supabase) ────────────────────────────────────

# [REQUIRED] Supabase project URL (public endpoint)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase anonymously public key (anon/publishable key, safe to expose on frontend)
# Note: This is NOT sensitive — it only allows public operations and auth flows
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_
