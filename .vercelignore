# Vercel should only deploy the frontend
# Ignore everything except apps/web

# Ignore root level files and directories
/*
!/.env
!/apps/

# Ignore all apps except frontend
/apps/*
!/apps/web/

# Explicitly ignore backend services
/apps/api/
/apps/*/
!/apps/web/

# Ignore documentation and config files
/docs/
*.md
!apps/web/**/*.md
